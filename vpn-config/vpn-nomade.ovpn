# ===================================================================
# VPN Nomade - Site Primaire
# Importer dans OpenVPN (Windows / macOS / Linux / iOS / Android)
# Entrer son login et mot de passe LDAP à la connexion
# ===================================================================

client
dev tun
proto udp

# Remplacer par l'IP publique (ou de gestion) du pare-feu ENT-FIREWALL
remote <IP_FIREWALL> 1194

resolv-retry infinite
nobind
persist-key
persist-tun

cipher AES-256-GCM
auth SHA256
tls-version-min 1.2

# Demande le login/mot de passe LDAP à la connexion
auth-user-pass

# TLS Auth : direction 1 côté client
key-direction 1

verb 3

<ca>
